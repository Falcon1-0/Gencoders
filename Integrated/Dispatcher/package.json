{
  "name": "fleetmind",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "start:integrated": "node server/integratedGateway.mjs",
    "build": "vite build",
    "build:integrated": "vite build --base /integrated/",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "vitest": "^4.1.4"
  }
}
